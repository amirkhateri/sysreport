name: sysreport
version: "@VERSION@"
arch: all
platform: linux
maintainer: "@AUTHOR@ <@EMAIL@>"
description: "@DESCRIPTION@"
license: "@LICENSE@"
homepage: "@HOMEPAGE@"
contents:
  - src: bin/sysreport
    dst: /usr/bin/sysreport
    file_info:
      mode: 0755
  - src: src/sysreport/core.sh
    dst: /usr/lib/sysreport/core.sh
    file_info:
      mode: 0644
  - src: src/sysreport/modules
    dst: /usr/lib/sysreport/modules
    file_info:
      mode: 0644
